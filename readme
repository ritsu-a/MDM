motion stat 300 t2m training (SeG_T2M, 需与 motion_stat_300 数据格式一致)

    CUDA_VISIBLE_DEVICES=1 python -m train.train_mdm \
    --save_dir save/SeG_T2M_t2m_beatNormalization \
    --dataset motion_stat_300 --save_interval 10000 \
    --data_dir ./data/SeG_T2M \
    --norm_data_dir ./data/BEAT_v2/segment_1wayne \
    --cond_mask_prob 0.1 \
    --overwrite

motion stat 300 t2m inference (SeG_T2M 训练出的模型；与训练一致指定 data_dir / norm_data_dir，inv_transform 才与训练时一致)
    CUDA_VISIBLE_DEVICES=2 python -m sample.generate \
    --model_path /root/workspace/motion-diffusion-model/save/SeG_T2M_t2m_beatNormalization/model000030000.pt \
    --dataset motion_stat_300 \
    --data_dir ./data/SeG_T2M \
    --norm_data_dir ./data/BEAT_v2/segment_1wayne \
    --text_prompt "The right arm is raised and extended outward to the side in a sweeping motion with the palm open, as if presenting or indicating something, before being lowered back to its resting position.
" \
    --motion_length 5 \
    --save_npz


render video


    python external/GMR/scripts/vis_npz_motion.py \
    --npz_path /root/workspace/motion-diffusion-model/save/SeG_T2M_t2m_beatNormalization/1/npz/sample0000.npz \
    --video_path test.mp4 \
    --motion_fps 60


BEAT_v2 segment_sem5s：批量把 segments/*.npz 渲染成视频（脚本会把 `motion` 键写成临时 `qpos` npz，因 vis_npz_motion 只读 `qpos`）

    # 在仓库根目录；需已安装 GMR/MuJoCo 等依赖（与单条 vis_npz_motion 相同环境）
    python prepare/render_concat_sem5s.py \
      --segments_dir data/BEAT_v2/segment_sem5s/segments \
      --out_dir outputs/sem5s_videos \
      --motion_fps 60 \
      --no_concat

    # 若同目录有同名 .wav，去掉 --no_mux_wav 可额外生成 *_with_wav.mp4；默认最后还会 concat 成 merged_with_wav.mp4
    python prepare/render_concat_sem5s.py \
      --segments_dir data/BEAT_v2/segment_sem5s/segments \
      --out_dir outputs/sem5s_videos \
      --motion_fps 60

    # 等价 shell：仅当 npz 内已是 `qpos` 键时可用（sem5s 片段默认是 `motion`，请用上一行的 prepare 脚本）
    SEG=data/BEAT_v2/segment_sem5s/segments
    OUT=outputs/sem5s_videos
    mkdir -p "$OUT"
    for f in "$SEG"/*.npz; do
      stem=$(basename "$f" .npz)
      python external/GMR/scripts/vis_npz_motion.py \
        --npz_path "$f" --video_path "$OUT/${stem}.mp4" --motion_fps 60
    done


render video (1-100) + merge wav + concat
    conda activate mdm310
    BASE=/DATA/disk1/data/synthetic_data/SG_2_or_3_long_sentence_1030_en
    for i in {1..100}; do
      python external/GMR/scripts/vis_npz_motion.py \
        --npz_path $BASE/${i}.npz \
        --video_path semi_videos/${i}.mp4 \
        --motion_fps 60

      ffmpeg -y -i semi_videos/${i}.mp4 -i $BASE/${i}.wav \
        -c:v copy -c:a aac -shortest semi_videos/${i}_with_wav.mp4
    done

    LIST="$(pwd)/semi_videos/concat_1_100.txt"
    : > "$LIST"
    for i in {1..100}; do
      echo "file '$(pwd)/semi_videos/${i}_with_wav.mp4'" >> "$LIST"
    done
    ffmpeg -y -f concat -safe 0 -i "$LIST" -c copy "$(pwd)/semi_videos/merged_1_100_with_wav.mp4"


beat a2m training
CUDA_VISIBLE_DEVICES=2 python -m train.train_mdm \
  --save_dir save/beat_v2_a2m_cfg \
  --dataset beat_v2 \
  --cond_mask_prob 0.1 \
  --overwrite

beat v2 a2m inference (single npz)
    CUDA_VISIBLE_DEVICES=2 python -m sample.generate_a2m \
    --model_path ./save/beat_v2_a2m/model000300000.pt \
    --dataset beat_v2 \
    --data_dir ./data/BEAT_v2/segment_1wayne \
    --input_npz /root/workspace/motion-diffusion-model/data/BEAT_v2/segment_1wayne/1_1_wayne_1_12_12_seg114.npz \
    --motion_frames 300 \
    --guidance_param 1.0 \
    --save_npz


wav 2 motion:
     python -m sample.generate_a2m_from_wav \
  --model_path ./save/beat_v2_a2m/model000300000.pt \
  --dataset beat_v2 \
  --data_dir ./data/BEAT_v2/segment_1wayne \
  --input_wav /root/workspace/motion-diffusion-model/data/BEAT_v2/8/8_catherine_0_1_1.wav \
  --guidance_param 1.0 \
  --save_npz --save_video --attach_wav


wav + chunked text prompts (dual t2m+a2m, weighted CFG noise):
    python -m sample.generate_a2m_t2m_from_wav \
  --a2m_model_path /root/workspace/motion-diffusion-model/save/beat_v2_a2m_cfg/model000100000.pt \
  --t2m_model_path /root/workspace/motion-diffusion-model/save/motion_stat_300_t2m_beatNormalization/model000250000.pt \
  --a2m_dataset beat_v2 \
  --t2m_dataset motion_stat_300 \
  --data_dir ./data/BEAT_v2/segment_1wayne \
  --input_wav /root/workspace/motion-diffusion-model/1_wayne_0_1_1.wav \
  --guidance_audio 1.0 --guidance_text 1.0 \
  --weight_audio 1.0 --weight_text 1.0 \
  --save_npz --save_video --attach_wav

prompts_per_chunk.txt:
  - one prompt per 5s chunk (aligned to chunking)
  - empty line means "disable text conditioning for this chunk"
  - if --prompts_path is omitted and <wav_dir>/<wav_base>.txt doesn't exist, the script will create <wav_dir>/<wav_base>.txt
    with ASR reference and a bracket prompt placeholder like: `...\t[my prompt]`. Edit inside `[ ... ]` and re-run.
  - optional: you can pass --prompts_path /path/to/custom.txt to use a custom location/name

output:
  - <out_dir>/results.npy
  - <out_dir>/npz/sample0000.npz
  - <out_dir>/videos/sample0000.mp4
  - <out_dir>/videos/sample0000_with_wav.mp4
  - per-chunk:
    - <out_dir>/chunks/repXXXX/npz/chunkYYYY.npz
    - <out_dir>/chunks/repXXXX/videos/chunkYYYY.mp4
    - if --attach_wav (requires ffmpeg + soundfile): chunkYYYY_with_wav.mp4






use api for text description:

export DMX_API_KEY=""
python api/batch_render_and_understand_videos.py \
  --videos-dir  outputs/sem5s_videos \
